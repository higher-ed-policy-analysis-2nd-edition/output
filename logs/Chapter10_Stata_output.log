. ********************************************************************************
. * SECTION 14: POLICY COST-BENEFIT ANALYSIS
. ********************************************************************************
. 
. local cost_per_degree = 50000

. local career_years    = 30

. local discount_rate   = 0.03

. local base_salary     = 47000

. local pv_factor = (1 - (1 + `discount_rate')^(-`career_years')) / `discount_rate'

. di "Present value factor (30 years, 3%): " %6.2f `pv_factor'
Present value factor (30 years, 3%):  19.60

. 
. di _n "--- Scenarios 1-4: Original MPRTE-based CBA ---"

--- Scenarios 1-4: Original MPRTE-based CBA ---

. di "Policy               MPRTE    Annual Gain   PV Gain    B/C Ratio"
Policy               MPRTE    Annual Gain   PV Gain    B/C Ratio

. di "=================================================================="
==================================================================

. foreach scen in unif lowinc stem ed {
  2.     if "`scen'" == "unif"   local mprte_val = `mprte_unif'
  3.     if "`scen'" == "lowinc" local mprte_val = `mprte_lowinc'
  4.     if "`scen'" == "stem"   local mprte_val = `mprte_stem'
  5.     if "`scen'" == "ed"     local mprte_val = `mprte_ed'
  6.     local annual_gain = `base_salary' * (exp(`mprte_val') - 1)
  7.     local pv_gain     = `annual_gain' * `pv_factor'
  8.     local bc_ratio    = `pv_gain' / `cost_per_degree'
  9.     if "`scen'" == "unif"   di "Uniform             " %6.4f `mprte_val' "   $" %6.0f `annua
> l_gain' "    $" %8.0f `pv_gain' "   " %5.2f `bc_ratio'
 10.     if "`scen'" == "lowinc" di "Low-income          " %6.4f `mprte_val' "   $" %6.0f `annua
> l_gain' "    $" %8.0f `pv_gain' "   " %5.2f `bc_ratio'
 11.     if "`scen'" == "stem"   di "STEM ug             " %6.4f `mprte_val' "   $" %6.0f `annua
> l_gain' "    $" %8.0f `pv_gain' "   " %5.2f `bc_ratio'
 12.     if "`scen'" == "ed"     di "Education ug        " %6.4f `mprte_val' "   $" %6.0f `annua
> l_gain' "    $" %8.0f `pv_gain' "   " %5.2f `bc_ratio'
 13. }
Uniform             0.9784   $ 78024    $ 1529307   30.59
Low-income          0.9336   $ 72548    $ 1421967   28.44
STEM ug             1.2367   $114875    $ 2251605   45.03
Education ug        1.1615   $103148    $ 2021749   40.43

